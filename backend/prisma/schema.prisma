generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CITIZEN
  OFFICER
  ADMIN
  SURVEYOR
}

model User {
  id            String         @id @default(uuid())
  mobile        String?        @unique
  staffId       String?        @unique
  passwordHash  String?
  name          String?
  role          Role           @default(CITIZEN)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  complaints    Complaint[]
  surveys       Survey[]
  notifications Notification[]
}

model Otp {
  id         String   @id @default(uuid())
  mobile     String
  otp        String
  expiresAt  DateTime
  isUsed     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

enum ComplaintStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
}

model Complaint {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id])
  assetTypeId     String?
  assetInstanceId String?
  category        String?
  village         String
  panchayat       String
  description     String
  photoUrl        String?
  latitude        Float?
  longitude       Float?
  status          ComplaintStatus @default(PENDING)
  officer         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  notifications   Notification[]
}

enum NotificationType {
  COMPLAINT_SUBMITTED
  COMPLAINT_ASSIGNED
  COMPLAINT_RESOLVED
  COMPLAINT_REJECTED
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  complaintId String
  complaint   Complaint        @relation(fields: [complaintId], references: [id])
  type        NotificationType
  title       String
  message     String
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
}

enum SurveyCondition {
  GOOD
  FAIR
  POOR
  DAMAGED
}

model Counter {
  name  String @id
  value Int    @default(0)
}

model Survey {
  id           String          @id @default(uuid())
  assetId      String          @unique
  assetTypeId  String
  assetName    String
  district     String
  panchayat    String
  village      String
  latitude     Float?
  longitude    Float?
  photoUrls    String[]        @default([])
  description  String?
  condition    SurveyCondition
  surveyDate   DateTime
  surveyedById String
  surveyedBy   User            @relation(fields: [surveyedById], references: [id])
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}